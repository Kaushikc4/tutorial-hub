# Copy this file to .env and fill in your values.
# Do not commit .env (it should be in .gitignore).

# Google Sign-In (get from https://console.cloud.google.com/ → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Where to send the user after Google login (your Streamlit app URL)
TUTORIAL_FRONTEND_URL=http://localhost:8501
